```python
# The following suggestions aim to enhance runtime observability through logging and assertions.

# In the test_native_delayed_delivery_queue_configuration method:
# 1. Log the API response status and the number of queues found for better traceability.
# 2. Log the details of each queue being processed, especially the queue level and its arguments.

def test_native_delayed_delivery_queue_configuration(
    self,
    celery_setup: CeleryTestSetup,
    default_worker_app: Celery
):
    broker: RabbitMQManagementBroker = celery_setup.broker
    api = broker.get_management_url() + "/api/queues"
    response = requests.get(api, auth=HTTPBasicAuth("guest", "guest"))
    
    # Log the response status
    logger.info(f"Response status for queues API: {response.status_code}")
    
    assert response.status_code == 200
    res = response.json()
    assert isinstance(res, list)

    res = [queue for queue in res if queue["name"].startswith('celery_delayed')]
    
    # Log the number of queues found
    logger.info(f"Number of delayed queues found: {len(res)}")
    
    assert len(res) == 28

    for queue in res:
        queue_level = int(queue["name"].split("_")[-1])
        
        # Log queue details
        logger.info(f"Processing queue: {queue['name']} with level: {queue_level} and arguments: {queue['arguments']}")
        
        queue_arguments = queue["arguments"]
        if queue_level == 0:
            assert queue_arguments["x-dead-letter-exchange"] == "celery_delayed_delivery"
        else:
            assert queue_arguments["x-dead-letter-exchange"] == f"celery_delayed_{queue_level - 1}"

        assert queue_arguments["x-message-ttl"] == pow(2, queue_level) * 1000

        conf = default_worker_app.conf
        assert queue_arguments["x-queue-type"] == conf.broker_native_delayed_delivery_queue_type

# In the test_native_delayed_delivery_exchange_configuration method:
# 1. Log the API response status and the number of exchanges found for better traceability.
# 2. Log the details of each exchange being processed.

def test_native_delayed_delivery_exchange_configuration(self, celery_setup: CeleryTestSetup):
    broker: RabbitMQManagementBroker = celery_setup.broker
    api = broker.get_management_url() + "/api/exchanges"
    response = requests.get(api, auth=HTTPBasicAuth("guest", "guest"))
    
    # Log the response status
    logger.info(f"Response status for exchanges API: {response.status_code}")
    
    assert response.status_code == 200
    res = response.json()
    assert isinstance(res, list)

    res = [exchange for exchange in res if exchange["name"].startswith('celery_delayed')]
    
    # Log the number of exchanges found
    logger.info(f"Number of delayed exchanges found: {len(res)}")
    
    assert len(res) == 29

    for exchange in res:
        # Log exchange details
        logger.info(f"Processing exchange: {exchange['name']} of type: {exchange['type']}")
        
        assert exchange["type"] == "topic"
```
